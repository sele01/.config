# ==========================================
# SKILL DEVELOPMENT & TYPING MECHANICS
# ==========================================

export TYPING_LESSONS="$HOME/.typing"

# Practice typing your recent shell usage patterns
practicehistory() {
    history | tail -n 20 | awk '{$1=""; print $0}' | ttyper -
}

# Shuffle specific punctuation keys to practice layouts
symbols() {
    python3 -c "
import random

s = list(r'!@#$%^&*()_+~-={}[]|\:;\"\'<>,.?/')
pool = s
random.shuffle(pool)

for i in range(1, len(pool)):
    if pool[i] == pool[i-1]:
        for j in range(i + 1, len(pool)):
            if pool[j] != pool[i]:
                pool[i], pool[j] = pool[j], pool[i]
                break

print(''.join(pool))
" > /tmp/symbols.txt && ttyper /tmp/symbols.txt
}

